# LinkedIn Posts via Apify (https://apify.com)
APIFY_API_TOKEN=
APIFY_ACTOR_ID=harvestapi~linkedin-post-search
APIFY_BASE_URL=https://api.apify.com

LINKEDIN_SEARCH_QUERIES=hiring frontend engineer,hiring senior frontend developer,hiring react developer,hiring full stack developer react,hiring javascript developer,hiring typescript developer,hiring software engineer frontend,hiring ui engineer,hiring web developer react,hiring next.js developer
LINKEDIN_POSTED_LIMIT=week
LINKEDIN_MAX_POSTS_PER_FETCH=50
LINKEDIN_MAX_RESULTS=50
LINKEDIN_MIN_EXPERIENCE_YEARS=2.5
LINKEDIN_FETCH_INTERVAL_HOURS=6
LINKEDIN_CACHE_FILE=data/linkedin-posts.json

LINKEDIN_QA_SEARCH_QUERIES=hiring QA engineer,hiring SDET,hiring QA automation engineer,hiring SDET engineer,hiring quality assurance engineer,hiring test automation engineer,hiring software development engineer in test,hiring automation tester,hiring senior SDET,hiring QA lead
LINKEDIN_QA_CACHE_FILE=data/linkedin-posts-qa.json

# Login credentials — used only by the login API route (not bundled into Edge middleware)
AUTH_ID=admin
AUTH_PASSWORD=

# Session cookie value — used by middleware; generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=

# ─── Netlify secret scanning ───────────────────────────────────────────────
# Mark ONLY these as "Secret" in Netlify UI:
#   APIFY_API_TOKEN, AUTH_PASSWORD, AUTH_SESSION_SECRET
# Do NOT mark config vars (LINKEDIN_*, APIFY_ACTOR_ID, etc.) as secrets.
# netlify.toml also sets SECRETS_SCAN_OMIT_PATHS for webpack cache folders.
